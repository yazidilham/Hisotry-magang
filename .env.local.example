# Salin file ini jadi .env.local lalu isi dengan nilai dari Supabase Dashboard
# Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# anon key: aman dipakai di browser, dipakai khusus untuk login/logout staff.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Service role key: JANGAN pernah taruh di kode frontend / commit ke git.
# Hanya dipakai di app/api/**/route.ts (server-side), dan hanya setelah
# sesi staff yang login berhasil diverifikasi.
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
